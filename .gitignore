# ============================================================================
# .gitignore  -  files and folders Git should never track
# ============================================================================

# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Virtual environments ---
venv/
env/
.venv/
ENV/

# --- IDE / editor settings ---
.vscode/
.idea/
*.swp
*~

# --- OS junk ---
Thumbs.db
Desktop.ini
.DS_Store

# --- App-specific ---
# (Git does NOT support trailing comments on pattern lines, so keep comments
#  on their own lines above each pattern.)

# Local DB credentials (never commit connection strings)
config/secrets.py

# Generated report files, but keep the empty folder in the repo
reports/exports/*
!reports/exports/.gitkeep

# Runtime log files, but keep the empty folder in the repo
logs/*.log
!logs/.gitkeep
